# ============================================================
# RallyLens environment example. Copy to .env and adjust.
# Never commit a real .env file.
# ============================================================

# ---- Backend ----
# Local zero-config dev uses SQLite. For Postgres (Docker Compose) use:
# DATABASE_URL=postgresql+psycopg2://rallylens:rallylens@db:5432/rallylens
DATABASE_URL=sqlite:///./rallylens.db

# Secret used to sign session JWTs. Generate a long random value in production.
SECRET_KEY=dev-insecure-change-me-please-0123456789

# Minutes a login session stays valid.
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Where uploaded videos, thumbnails and preview frames are stored locally.
STORAGE_DIR=./storage

# Comma-separated list of allowed CORS origins for the API.
CORS_ORIGINS=http://localhost:3000

# ---- Frontend ----
# Base URL the browser uses to reach the API.
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---- Postgres (used by docker-compose) ----
POSTGRES_USER=rallylens
POSTGRES_PASSWORD=rallylens
POSTGRES_DB=rallylens
